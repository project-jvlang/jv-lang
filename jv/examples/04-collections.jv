fun main() {
    val numbers = [1 2 3 4 5]
    
    // Map
    val doubled = numbers.map { i -> i * 2 }
    println("Doubled: ${doubled}")
    
    // Filter
    val evens = numbers.filter { i -> i % 2 == 0 }
    println("Evens: ${evens}")
    
    // Reduce
    val sum = numbers.reduce { (acc, x) -> acc + x }
    println("Sum: ${sum}")
}
