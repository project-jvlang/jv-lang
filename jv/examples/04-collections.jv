fun main() {
    val numbers = listOf(1, 2, 3, 4, 5)
    
    // Map
    val doubled = numbers.map { it * 2 }
    println("Doubled: ${doubled}")
    
    // Filter
    val evens = numbers.filter { it % 2 == 0 }
    println("Evens: ${evens}")
    
    // Reduce
    val sum = numbers.reduce { acc, x -> acc + x }
    println("Sum: ${sum}")
}